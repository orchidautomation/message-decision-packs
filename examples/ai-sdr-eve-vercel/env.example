# Eve / model routing
# On Vercel, string model ids route through Vercel AI Gateway with project auth.
MDP_SCOUT_MODEL=xai/grok-4.5

# MDP runtime. `simulated` is fixture-safe. `native` requires an `mdp` binary in the app runtime.
MDP_RUNNER_MODE=simulated
MDP_BIN=mdp
MDP_PACK_ROOT=.

# Discovery. Explicit dry-runs use samples/synthetic-public-source-fixture.json.
# Live and Cron runs require EXA_API_KEY and fail closed when it is absent.
# Exa is wired through a local Vercel AI SDK `tool()` wrapper for ai@7/Eve compatibility.
EXA_API_KEY=

# Optional accepted-URL cleanup. The agent skips Firecrawl when the key is absent.
FIRECRAWL_API_KEY=

# Optional advanced lane. Apify MCP/Actor execution is intentionally deferred from this first slice.
APIFY_TOKEN=

# Ledger output is append-only JSONL. On Vercel this path is ephemeral until Blob/DB is added.
SCOUT_OUTPUT_DIR=artifacts
SCOUT_MAX_CANDIDATES=5
SCOUT_MIN_SCORE=65
CRM_SYNC_ENABLED=false
