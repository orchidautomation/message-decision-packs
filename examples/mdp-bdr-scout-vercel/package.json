{
  "name": "mdp-bdr-scout-vercel",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check:scaffold": "node scripts/check-example.mjs",
    "typecheck": "next typegen && tsc --noEmit",
