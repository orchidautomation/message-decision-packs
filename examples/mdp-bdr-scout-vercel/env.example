# Required for the cron entrypoint. The route refuses requests until this is set.
CRON_SECRET=change-me

# Required for live discovery/extraction.
EXA_API_KEY=
DATABASE_URL=
BLOB_READ_WRITE_TOKEN=

# Vercel AI Gateway uses OIDC on Vercel. Local/non-Vercel fallback only.
AI_GATEWAY_API_KEY=

# Optional extraction/tool providers.
FIRECRAWL_API_KEY=
APIFY_TOKEN=

# MDP execution.
MDP_RUNNER_MODE=simulated
MDP_BIN=mdp
MDP_PACK_DIR=
# Optional path to an mdp.source-strategy.v0 JSON artifact. Defaults to samples/source-strategy.json.
SCOUT_SOURCE_STRATEGY_PATH=

# Scout controls.
SCOUT_MIN_SCORE=70
SCOUT_MAX_CANDIDATES=25
CRM_SYNC_ENABLED=false
SALESFORCE_CONNECTOR_ID=
ATTIO_CONNECTOR_ID=

# Local/dev fallback only, not the default production path.
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
