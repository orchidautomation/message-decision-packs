# Required for the cron entrypoint. Generate a random value and set it in Vercel.
CRON_SECRET=change-me

# Profound demo defaults. These files are committed inside this Vercel example so the cron can run before live keys are added.
MDP_PACK_ID=profound-gtm-vetting-example
SCOUT_SOURCE_STRATEGY_PATH=samples/profound-source-strategy.json
SCOUT_FIXTURE_PATH=samples/profound-public-source-fixture.json
SCOUT_OUTPUT_DIR=/tmp/mdp-bdr-scout
SCOUT_SCHEDULE_ID=weekday-profound-scout

# Add these two keys to move from dry-run public fixtures to live provider work.
EXA_API_KEY=
APIFY_TOKEN=

# Optional provider/model settings.
FIRECRAWL_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
AI_GATEWAY_API_KEY=
MDP_SCOUT_MODEL=openai/gpt-5.4-mini

# MDP execution. Use simulated in Vercel unless the deployment explicitly ships a trusted mdp binary/sandbox runner.
MDP_RUNNER_MODE=simulated
MDP_BIN=mdp
MDP_PACK_DIR=

# Scout controls.
SCOUT_MIN_SCORE=70
SCOUT_MAX_CANDIDATES=25
CRM_SYNC_ENABLED=false
SALESFORCE_CONNECTOR_ID=
ATTIO_CONNECTOR_ID=
